# Pickrack environment variables — copy to .env.production (or .env.local for dev) and fill in.
# DO NOT commit your real .env files. Only this template is committed.

# ─────────── Required for AI tools (only) ───────────
# Get a key at https://console.anthropic.com/settings/keys
# Set a spend limit ($20/month is reasonable for a single-instance deploy).
# Without this key, /tools/ai/* tools return an error; everything else still works.
ANTHROPIC_API_KEY=

# ─────────── Optional: Analytics ───────────
# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
# Leave empty to skip GA injection.
NEXT_PUBLIC_GA_ID=

# Google AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
# Leave empty to skip AdSense.
NEXT_PUBLIC_ADSENSE_CLIENT=

# ─────────── Optional: AI image tools (self-hosted GPU worker) ───────────
# Base URL of a self-hosted GPU worker that backs the 3 AI image tools:
#   /tools/ai/qr-art-generator  → POSTs to <URL>/generate
#   /tools/ai/ai-image-upscaler → POSTs to <URL>/upscale
#   /tools/ai/ai-img2img        → POSTs to <URL>/img2img
# A readiness probe hits <URL>/health first. Without this var, those 3 tools
# return a clear "GPU worker offline" error; all Claude-backed AI tools and the
# rest of the site work normally.
# Example: QR_ART_LOCAL_URL=http://127.0.0.1:3021
QR_ART_LOCAL_URL=
